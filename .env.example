# URL de conexão com o Postgres (driver psycopg v3)
# Formato: postgresql+psycopg://usuario:senha@host:porta/nome_do_banco
# Se estiver usando o docker-compose.yml deste projeto, os valores já batem com ele.
DATABASE_URL=postgresql+psycopg://admin:admin123@localhost:5432/encurtador

# Segredo usado para assinar os tokens JWT.
# Gere um valor forte em produção, por exemplo com: openssl rand -hex 32
JWT_SECRET_KEY=troque-por-uma-chave-secreta-forte

# Algoritmo de assinatura do JWT (não precisa mudar)
JWT_ALGORITHM=HS256

# Tempo de expiração do token, em minutos (1440 = 24 horas)
JWT_EXPIRE_MINUTES=1440
